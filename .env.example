# MarkHub Docker / Compose environment template
# Copy to `.env` before `docker compose up --build`:
#   cp .env.example .env
#   # or: ./scripts/generate-docker-env.sh
#
# Never commit a real `.env`. All secrets below are placeholders — replace them.

# Required secrets for every Compose path (compose fails fast if missing).
# POSTGRES_PASSWORD is required even for SQLite-only runs because Compose
# interpolates profiled service definitions at config time.
JWT_SECRET=replace-with-long-random-string
MARKHUB_MASTER_KEY=replace-with-master-key-at-least-24-chars
DEFAULT_ADMIN_PASSWORD=replace-with-strong-admin-password
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# Optional admin bootstrap
DEFAULT_ADMIN_USERNAME=admin
FORCE_ADMIN_PASSWORD_CHANGE=true

# SQLite default (markhub service). Override only if needed.
# DATABASE_URL=sqlite+aiosqlite:///./data/markhub.db

# Used by: docker compose --profile postgres-app up --build
# Prefer URL-safe characters (A-Za-z0-9) so DATABASE_URL stays valid.
POSTGRES_USER=markhub
POSTGRES_DB=markhub

# Optional CORS (comma-separated origins, or * for any)
# CORS_ORIGINS=*
